PORT=4000
# Exact approved origins only (comma-separated). No wildcard *.onrender.com.
CORS_ORIGIN=http://localhost:5173
CORS_EXTRA_ORIGIN=http://localhost:5174
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JSON_BODY_LIMIT=100kb

# Demo seeding is for local/dev/test only. Production refuses to start when true.
ENABLE_DEMO_DATA=true
# DEMO_SEED_PASSWORD=DemoSeed-ChangeMe1
# ALLOW_SIMULATED_OAUTH=true
# REQUIRE_MFA=true

# Neon PostgreSQL — when set, auth/orders/listings persist to the database.
# Omit to use in-memory storage (used by CI/tests).
DATABASE_URL=
