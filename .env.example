# Use /api with `npm run dev:all` (Vite proxies to the backend on port 4000)
# VITE_API_BASE_URL=/api

# Recommended for local dev when API runs on port 4000 (works with npm run dev:all or dev:server + dev)
VITE_API_BASE_URL=http://localhost:4000/api

# Demo API accounts (when backend is running):
# seller@gridstore.local / demo1234
# buyer@gridstore.local / demo1234
VITE_API_TIMEOUT_MS=10000
VITE_API_MONITOR_MS=20000
VITE_PUBLIC_WEB_URL=http://localhost:5173
VITE_PUBLIC_ADMIN_URL=http://localhost:5174
VITE_IDLE_TIMEOUT_MS=1200000
VITE_IDLE_PROMPT_SECONDS=30
# Marketplace app uses /admin routes; standalone ops app uses empty string
VITE_ADMIN_BASE_PATH=/admin

# Backend (see server/.env.example):
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Optional endpoint overrides (defaults shown)
VITE_API_PRODUCTS_PATH=/products
VITE_API_PRODUCT_PATH=/products/:id
VITE_API_SERVICES_PATH=/services
VITE_API_RENTALS_PATH=/rentals
VITE_API_JOBS_PATH=/jobs
VITE_API_STORES_PATH=/stores
VITE_API_AI_ASSISTANT_PATH=/ai/assist
